function searchStudents() {
    const searchTerm = $('#searchName').val().trim();

    // Only perform search if there's actually a search term
    if (searchTerm) {
        $.getJSON(`/students?name=${encodeURIComponent(searchTerm)}`, function(data) {
            if (data.students && data.students.length > 0) {
                updateStudentsTable(data.students);
            } else {
                // Handle no results found
                $('#studentsList').empty();
                $('#studentsList').append(`
                    <tr>
                        <td colspan="7" class="text-center">No students found matching "${searchTerm}"</td>
                    </tr>
                `);
            }
        }).fail(function(jqXHR, textStatus, errorThrown) {
            // Handle errors
            console.error('Search failed:', errorThrown);
            alert('Error performing search. Please try again.');
        });
    } else {
        // If search is empty, show all students
        fetchStudents();
    }
}

// Make sure you have these event listeners:
$(document).ready(function() {
    // Search when Enter key is pressed
    $('#searchName').on('keyup', function(e) {
        if (e.key === 'Enter') {
            searchStudents();
        }
    });

    // Search when search button is clicked
    $('#searchButton').on('click', function() {
        searchStudents();
    });

    // Clear search and show all students
    $('#clearSearch').on('click', function() {
        $('#searchName').val('');
        fetchStudents();
    });
});
