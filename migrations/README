// Modify your existing fetchStudents function to use a common update function
function fetchStudents() {
    $.getJSON('/students', function(data) {
        updateStudentsTable(data.students);
    });
}

// Create a new function to update the table
function updateStudentsTable(students) {
    $('#studentsList').empty();
    students.forEach(student => {
        const photoHtml = student.photo_url
            ? `<img src="${student.photo_url}" alt="Student photo" style="width: 50px; height: 50px; object-fit: cover;">`
            : 'No photo';

        $('#studentsList').append(`
            <tr>
                <td>${student.id}</td>
                <td>${student.first_name}</td>

                <td>${student.birth_date}</td>
                <td>${student.age}</td>
                <td>${student.course_name}</td>
                <td>${photoHtml}</td>
                <td>
                    <button class="btn btn-warning btn-sm" onclick="updateStudent(${student.id})">
                        <i class="fas fa-edit"></i> Edit
                    </button>
                    <button class="btn btn-danger btn-sm" onclick="deleteStudent(${student.id})">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </td>
            </tr>
        `);
    });
}

